{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4a5b-bc6d-7e8f9a0b1c2d",
		"name": "Telecom Billing Security Audit",
		"description": "Коллекция для тестирования уязвимостей и исправлений в биллинговой системе (Вариант 6).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Vulnerability Tests (Exploits)",
			"item": [
				{
					"name": "Command Injection (RCE attempt)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/debug/ping?host=8.8.8.8; cat /etc/passwd",
							"host": ["{{baseUrl}}"],
							"path": ["debug", "ping"],
							"query": [
								{
									"key": "host",
									"value": "8.8.8.8; cat /etc/passwd",
									"description": "Попытка выполнить вторую команду через точку с запятой"
								}
							]
						},
						"description": "В исправленной версии должен вернуть 400 Bad Request из-за валидации символов."
					}
				},
				{
					"name": "Path Traversal (Sensitive file read)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/debug/read-config?filename=../../../../etc/passwd",
							"host": ["{{baseUrl}}"],
							"path": ["debug", "read-config"],
							"query": [
								{
									"key": "filename",
									"value": "../../../../etc/passwd",
									"description": "Попытка выйти из папки configs"
								}
							]
						},
						"description": "Должен вернуть 403 Forbidden, так как путь выходит за пределы SAFE_DIR."
					}
				},
				{
					"name": "SQL Injection (Bypass via OR)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/debug/search-users?username=' OR '1'='1",
							"host": ["{{baseUrl}}"],
							"path": ["debug", "search-users"],
							"query": [
								{
									"key": "username",
									"value": "' OR '1'='1",
									"description": "Попытка выгрузить всех пользователей"
								}
							]
						},
						"description": "Должен вернуть пустой список или 404, так как запрос параметризован."
					}
				},
				{
					"name": "Stored XSS (Script injection)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/debug/greet?name=<script>alert('xss')</script>",
							"host": ["{{baseUrl}}"],
							"path": ["debug", "greet"],
							"query": [
								{
									"key": "name",
									"value": "<script>alert('xss')</script>",
									"description": "Инъекция скрипта"
								}
							]
						},
						"description": "В ответе скрипт должен быть заэкранирован (текст, а не исполняемый код)."
					}
				},
				{
					"name": "Legacy Login Bypass (SQLi)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "admin",
									"type": "text"
								},
								{
									"key": "password",
									"value": "' OR '1'='1",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/debug/legacy-login",
							"host": ["{{baseUrl}}"],
							"path": ["debug", "legacy-login"]
						},
						"description": "Попытка входа без пароля."
					}
				}
			]
		},
		{
			"name": "Standard API Operations",
			"item": [
				{
					"name": "Ping Google (Safe)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/debug/ping?host=8.8.8.8",
							"host": ["{{baseUrl}}"],
							"path": ["debug", "ping"],
							"query": [
								{
									"key": "host",
									"value": "8.8.8.8"
								}
							]
						}
					}
				},
				{
					"name": "Get Debug Info",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/debug/debug-info",
							"host": ["{{baseUrl}}"],
							"path": ["debug", "debug-info"]
						}
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000",
			"type": "string"
		}
	]
}